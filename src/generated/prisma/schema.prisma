generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Chain {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String?
  iconUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotWallets           HotWallet[]
  caseSeedTransactions CaseSeedTransaction[]
  flows                Flow[]
  flowTransactions     FlowTransaction[]
}

enum FlowEndpointReason {
  EXCHANGE_HOT_WALLET
  MAX_HOPS_REACHED
  NO_OUTGOING_ABOVE_THRESHOLD
  CYCLE_DETECTED
  NO_OUTBOUND
  EXHAUSTED_OPTIONS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases Case[]
}

model Exchange {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  iconUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hotWallets HotWallet[]
}

model Token {
  id            String    @id @default(cuid())
  coingeckoId   String    @unique
  name          String
  symbol        String
  imageUrl      String?
  currentPrice  String?
  marketCap     String?
  marketCapRank Int?
  totalVolume   String?
  lastUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model HotWallet {
  id         String   @id @default(cuid())
  exchangeId String
  exchange   Exchange @relation(fields: [exchangeId], references: [id])
  chainId    String
  chain      Chain    @relation(fields: [chainId], references: [id])
  address    String
  label      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  flowsAsEndpoint Flow[]

  @@unique([exchangeId, chainId, address])
}

enum CaseStatus {
  OPEN // Aguardando processamento
  PROCESSING // Processando caso
  COMPLETED // Encontrou hot wallet
  PARTIALLY // Chegou ao fim sem encontrar hot wallet
  FAILED // Erro interno do sistema
}

model Case {
  id                     String     @id @default(cuid())
  externalId             String?    @unique
  name                   String
  status                 CaseStatus @default(OPEN)
  createdByUserId        String
  createdByUser          User       @relation(fields: [createdByUserId], references: [id])
  totalAmountLostRaw     String
  totalAmountLostDecimal String
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  seeds        CaseSeedTransaction[]
  flows        Flow[]
  reports      CaseReport[]
  traceMetrics TraceMetric[]
}

enum ReportFormat {
  PDF
  DOCX
}

model CaseReport {
  id          String       @id @default(cuid())
  caseId      String
  case        Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  format      ReportFormat
  generatedAt DateTime
  storageKey  String
  createdAt   DateTime     @default(now())

  @@index([caseId])
  @@index([caseId, generatedAt])
}

model CaseSeedTransaction {
  id            String   @id @default(cuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id])
  chainId       String
  chain         Chain    @relation(fields: [chainId], references: [id])
  txHash        String
  tokenAddress  String?
  tokenSymbol   String?
  amountRaw     String
  amountDecimal String
  timestamp     DateTime
  createdAt     DateTime @default(now())

  flows Flow[]
}

model Flow {
  id                  String              @id @default(cuid())
  caseId              String
  case                Case                @relation(fields: [caseId], references: [id])
  seedId              String
  seed                CaseSeedTransaction @relation(fields: [seedId], references: [id])
  chainId             String
  chain               Chain               @relation(fields: [chainId], references: [id])
  tokenAddress        String?
  tokenSymbol         String?
  totalAmountRaw      String
  totalAmountDecimal  String
  hopsCount           Int
  endpointAddress     String
  endpointReason      FlowEndpointReason
  endpointHotWalletId String?
  endpointHotWallet   HotWallet?          @relation(fields: [endpointHotWalletId], references: [id])
  isEndpointExchange  Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?

  transactions FlowTransaction[]
  edges        FlowEdge[]
  wallets      FlowWallet[]
}

model FlowWallet {
  id        String   @id @default(cuid())
  flowId    String
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  nodeIndex Int
  address   String
  nickname  String?
  position  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([flowId, nodeIndex])
}

model FlowTransaction {
  id            String    @id @default(cuid())
  flowId        String
  flow          Flow      @relation(fields: [flowId], references: [id])
  chainId       String
  chain         Chain     @relation(fields: [chainId], references: [id])
  hopIndex      Int
  txHash        String
  fromAddress   String
  toAddress     String
  tokenAddress  String?
  tokenSymbol   String?
  amountRaw     String
  amountDecimal String
  timestamp     DateTime
  isEndpointHop Boolean   @default(false)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  @@unique([flowId, hopIndex])
}

model FlowEdge {
  id                    String           @id @default(cuid())
  flowId                String
  flow                  Flow             @relation(fields: [flowId], references: [id], onDelete: Cascade)
  stepIndex             Int
  fromAddress           String
  toAddress             String
  transferSymbol        String?
  transferAmountRaw     String?
  transferAmountDecimal String?
  txHash                String?
  tokenAddress          String?
  outcome               FlowEdgeOutcome?
  transferTimestamp     DateTime?
  createdAt             DateTime         @default(now())
  deletedAt             DateTime?

  @@unique([flowId, stepIndex])
}

enum FlowEdgeOutcome {
  SUCCESS
  NO_OUTBOUND
  MAX_WALLETS_REACHED
  EXHAUSTED_OPTIONS
}

enum FlowTraceLogStatus {
  SUCCESS
  NO_OUTBOUND
  MAX_WALLETS_REACHED
  EXHAUSTED_OPTIONS
}

model FlowTraceLog {
  id               String             @id @default(cuid())
  inputAddress     String
  chainSlug        String
  status           FlowTraceLogStatus
  endpointAddress  String?
  failureAtAddress String?
  failureReason    String?
  stepsCount       Int                @default(0)
  createdAt        DateTime           @default(now())

  steps FlowTraceLogStep[]
}

model FlowTraceLogStep {
  id                    String              @id @default(cuid())
  flowTraceLogId        String
  flowTraceLog          FlowTraceLog        @relation(fields: [flowTraceLogId], references: [id], onDelete: Cascade)
  stepIndex             Int
  fromAddress           String
  toAddress             String
  transferSymbol        String?
  transferAmountRaw     String?
  transferAmountDecimal String?
  txHash                String?
  outcome               FlowTraceLogStatus?
  createdAt             DateTime            @default(now())

  @@unique([flowTraceLogId, stepIndex])
}

model TraceMetric {
  id                  String   @id @default(cuid())
  caseId              String?
  case                Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  traceId             String
  seedIndex           Int?
  mode                String?
  success             Boolean
  totalDurationMs     Int
  exchangeFoundAtMs   Int?
  flowDurationsJson   Json?
  walletDurationsJson Json?
  createdAt           DateTime @default(now())

  @@index([caseId])
  @@index([traceId])
}
